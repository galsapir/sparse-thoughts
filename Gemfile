# ABOUTME: Defines Ruby dependencies needed to build Sparse Thoughts locally.
# ABOUTME: Keeps Jekyll plugins available for local verification and deployment.
source "https://rubygems.org"

gem "jekyll", "~> 4.3"

group :jekyll_plugins do
  gem "jekyll-paginate"
  gem "jekyll-redirect-from"
  gem "jekyll-seo-tag"
  gem "jekyll-sitemap"
end
